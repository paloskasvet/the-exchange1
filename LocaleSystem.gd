# Returns the translated string for the given key.
# Falls back to English, then to the raw key if not found.
func get_tr(key: String) -> String:
	var d: Dictionary = STRINGS.get(current_language, STRINGS["en"])
	return d.get(key, STRINGS["en"].get(key, key))

# Returns the localised name for an office level (0-3).
func office_name(level: int) -> String:
	return get_tr("OFFICE_%d" % level)

func set_language(lang: String) -> void:
	if lang == current_language or lang not in STRINGS:
		return
	current_language = lang
	emit_signal("language_changed")
